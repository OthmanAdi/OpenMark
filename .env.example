# ── Embedding ────────────────────────────────────────────────────────────
# Three providers: pplx (local, free, recommended), azure, local
EMBEDDING_PROVIDER=pplx
PPLX_QUERY_MODEL=perplexity-ai/pplx-embed-v1-0.6b
PPLX_DOC_MODEL=perplexity-ai/pplx-embed-context-v1-0.6b

# ── Azure AI Foundry — the LLM stack ────────────────────────────────────
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_KEY=your-azure-api-key
AZURE_API_VERSION=2025-04-01-preview
AZURE_DEPLOYMENT_EMBED=text-embedding-3-large

# ── Agent provider ──────────────────────────────────────────────────────
# azure (default — uses Foundry deployments via OPENMARK_MODEL_* below)
# local (uses BONSAI_URL / BONSAI_MODEL via an OpenAI-compatible server)
AGENT_PROVIDER=azure
BONSAI_URL=http://localhost:11434/v1
BONSAI_MODEL=hermes3:8b

# ── v3 role → Foundry deployment (preferred; takes precedence over legacy) ──
# Sensible defaults shipped in openmark/models/router.py — uncomment to override.
# OPENMARK_MODEL_ORCHESTRATOR=gpt-5.5
# OPENMARK_MODEL_CLASSIFIER=gpt-4.1-mini
# OPENMARK_MODEL_SUMMARIZER=gpt-4.1-mini
# OPENMARK_MODEL_RESEARCHER=gpt-5.3-codex
# OPENMARK_MODEL_COMPOSER=gpt-5.5
# OPENMARK_MODEL_HUMANIZER=gpt-5
# OPENMARK_MODEL_POLISHER=gpt-4.1-mini
# OPENMARK_MODEL_VERIFIER=gpt-5-mini
# OPENMARK_MODEL_SKILL_AUTHOR=gpt-4.1-mini

# ── Legacy back-compat (still honored if OPENMARK_MODEL_* unset) ────────
AZURE_DEPLOYMENT_EXECUTOR=grok-4.3              # orchestrator + researcher
AZURE_DEPLOYMENT_CLASSIFIER=gpt-4.1-mini        # summarizer + classifier + polisher + skill_author
AZURE_DEPLOYMENT_SYNTHESIZER=gpt-5.3-codex      # composer + humanizer
AZURE_DEPLOYMENT_PLANNER=gpt-5.3-codex          # verifier
AZURE_REASONING_EXECUTOR=high
AZURE_REASONING_CLASSIFIER=low
AZURE_REASONING_SYNTHESIZER=high
AZURE_REASONING_PLANNER=high
AZURE_VERBOSITY_SYNTHESIZER=medium

# ── Neo4j (required) ────────────────────────────────────────────────────
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=openmark

# ── Web research (optional but recommended) ────────────────────────────
TAVILY_API_KEY=your-tavily-key          # unlocks web_search / web_fetch / web_extract / web_crawl
BRAVE_API_KEY=your-brave-key            # web_search fallback
GITHUB_TOKEN=your-github-token          # raises api.github.com rate limit (60/hr → 5000/hr)

# ── Raindrop (optional) ────────────────────────────────────────────────
RAINDROP_TOKEN=your-raindrop-token
RAINDROP_MISSION_DIR=C:\Users\yourname\Documents\raindrop-mission

# ── HuggingFace (optional) ─────────────────────────────────────────────
HF_TOKEN=your-hf-token                  # silences "unauthenticated" warning on pplx-embed download

# ── Newsletter / Publish layer ─────────────────────────────────────────
# Resend.com outbound email — 3,000 emails/month free tier. Get key at
# https://resend.com/api-keys . Verify your domain first.
RESEND_API_KEY=re_your_resend_api_key

# The "From:" address on outbound emails. Must be on a domain you verified
# with Resend (Sender Domain → add DKIM/SPF records).
PUBLISH_FROM_EMAIL=ahmad@yourdomain.dev
PUBLISH_REPLY_TO=ahmad@yourdomain.dev
PUBLISH_BASE_URL=https://yourdomain.dev
PUBLICATION_NAME=OpenMark

# ── LinkedIn (cookie-based posting via Voyager API) ────────────────────
# Same auth path your bookmark fetcher uses. Grab li_at from your browser:
# DevTools → Application → Cookies → linkedin.com → li_at .
# JSESSIONID is the value next to it, including the "ajax:" prefix.
# Rotate these when LinkedIn invalidates your session (~once a month).
LINKEDIN_LI_AT=AQEDA...
LINKEDIN_JSESSIONID=ajax:1234567890123456789
