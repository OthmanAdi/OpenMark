# Embedding Provider: pplx (local, free), azure, or local
EMBEDDING_PROVIDER=pplx
PPLX_QUERY_MODEL=perplexity-ai/pplx-embed-v1-0.6b
PPLX_DOC_MODEL=perplexity-ai/pplx-embed-context-v1-0.6b

# Azure AI (used when EMBEDDING_PROVIDER=azure or AGENT_PROVIDER=azure)
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_KEY=your-azure-api-key
AZURE_DEPLOYMENT_LLM=gpt-4o-mini
AZURE_DEPLOYMENT_EMBED=text-embedding-3-large
AZURE_API_VERSION=2025-01-01-preview

# Agent LLM: azure (default) or local (Bonsai via llama-server)
AGENT_PROVIDER=azure
BONSAI_URL=http://localhost:8080/v1
BONSAI_MODEL=bonsai-1.7b

# Neo4j (required)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=openmark

# Raindrop (optional - for live bookmark pull)
RAINDROP_TOKEN=your-raindrop-token

# Data paths (adjust to your machine)
RAINDROP_MISSION_DIR=C:\Users\yourname\Documents\raindrop-mission
CHROMA_PATH=C:\Users\yourname\Documents\OpenMark\data\chroma_db

# HuggingFace (optional - faster model downloads)
HF_TOKEN=your-hf-token
