---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="You're in" description="Subscription confirmed.">
  <div class="text-center py-20">
    <p class="text-6xl mb-6">✉</p>
    <h1 class="text-3xl font-bold text-ink mb-2">You're in.</h1>
    <p class="text-muted">
      First issue lands in your inbox on the next send. Until then —
      <a href="/issues/" class="text-accent hover:underline">browse the archive</a>.
    </p>
  </div>
</BaseLayout>
