---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Unsubscribed" description="You've been removed from the list.">
  <div class="text-center py-20">
    <p class="text-6xl mb-6">👋</p>
    <h1 class="text-3xl font-bold text-ink mb-2">You're out.</h1>
    <p class="text-muted">
      No more emails. If this was a mistake, you can
      <a href="/subscribe/" class="text-accent hover:underline">re-subscribe</a> any time.
    </p>
  </div>
</BaseLayout>
