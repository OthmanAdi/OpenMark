---
// Subscribe form. Posts to /api/subscribe, which is a Cloudflare Pages
// Function (site/functions/api/subscribe.ts) running on the edge. It writes
// the pending row into the bound D1 database and triggers a Resend confirm-
// link email. The Function 303-redirects back to /subscribe?status=sent.
//
// Override the endpoint by setting PUBLIC_PUBLISH_API_URL at build time if
// you're hosting somewhere other than Cloudflare Pages.

const API_URL = import.meta.env.PUBLIC_PUBLISH_API_URL || '/api/subscribe';
---
<form
  method="POST"
  action={API_URL}
  class="flex flex-col sm:flex-row gap-3 max-w-md"
>
  <input
    type="email"
    name="email"
    required
    autocomplete="email"
    placeholder="you@somewhere.dev"
    class="flex-1 px-4 py-2 rounded-md border border-rule focus:border-accent focus:outline-none text-base"
  />
  <input type="hidden" name="source" value="site" />
  <button
    type="submit"
    class="px-5 py-2 rounded-md bg-ink text-white font-medium hover:bg-accent transition-colors"
  >
    Subscribe
  </button>
</form>
<p class="mt-2 text-xs text-muted">
  Double opt-in. We email a confirm link, you click it, we add you. Unsubscribe in every issue.
</p>
